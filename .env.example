# ─────────────────────────────────────────────────────────────
# Wilduit VoiceMeet — Variables de Entorno
# Copia este archivo como .env.local para desarrollo local
# ─────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=genera_uno_con: openssl rand -base64 32
NEXTAUTH_URL=https://tu-app.vercel.app

# ── Google OAuth ──────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Habilitar: Google Calendar API, Drive API, Gmail API
# Redirect URI: https://tu-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxx

# ── Vercel KV ─────────────────────────────────────────────────
# vercel.com → tu proyecto → Storage → Create KV
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# ── Vercel Blob ───────────────────────────────────────────────
# vercel.com → tu proyecto → Storage → Create Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Recall.ai (bot de grabación) ──────────────────────────────
# app.recall.ai → Settings → API Keys
# También configura el Webhook en: Settings → Webhooks
# URL: https://tu-app.vercel.app/api/recall/webhook
# Evento: bot.status_change
# (Se guarda en la app desde Configuración, no aquí)
